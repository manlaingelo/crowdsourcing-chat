# Reference for ALL environment variables across the project.
# Copy the relevant blocks into backend/.env and frontend/.env.

# ============================================================
# BACKEND  (copy to backend/.env)
# ============================================================
GOOGLE_API_KEY=<GOOGLE_AI_STUDIO_API_KEY>

PINECONE_API_KEY=<PINECONE_API_KEY>
PINECONE_INDEX_NAME=products
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

TAVILY_API_KEY=<TAVILY_API_KEY>

GITHUB_TOKEN=<GITHUB_PERSONAL_ACCESS_TOKEN>
GITHUB_REPO_OWNER=<GITHUB_OWNER>
GITHUB_REPO_NAME=<GITHUB_REPO>

CONFIDENCE_THRESHOLD=0.70
TOP_K=5
FALLBACK_TO_WEB=true
ENABLE_DATA_CONTRIBUTION=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# FRONTEND  (copy to frontend/.env)
# ============================================================
VITE_BACKEND_URL=http://localhost:7860
